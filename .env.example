# Proje kökünde `.env.local` olarak kaydedin (package.json ile aynı klasör). UTF-8, BOM kullanmayın.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# DNS hatası (ENOTFOUND) görürseniz: Supabase Dashboard → Settings → API ile URL'nin tam olarak eşleştiğini doğrulayın.
#
# Yerelde auth olmadan çalışmak için (marketing sayfaları, önizleme):
# NEXT_PUBLIC_HOOKERRA_DISABLE_SUPABASE=1
# Sunucu tarafı için ek olarak: HOOKERRA_DISABLE_SUPABASE=1

# Dashboard → Settings → API:
# - Yeni arayüz: "Publishable" / `sb_publishable_…` buraya yazılabilir
# - Klasik: "anon" "public" JWT (`eyJhbGciOi…`) — ikisi de NEXT_PUBLIC_SUPABASE_ANON_KEY olarak kullanılabilir
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

GEMINI_API_KEY=your_gemini_key
# İsteğe bağlı — varsayılan: gemini-2.5-flash (@google/genai). Sorun olursa: gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Supabase Dashboard "Site URL" ile uyumlu olsun (genelde http://localhost:3000 veya prod kökü).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: gelirdiğiniz adresle aynı olmalı (localhost ve 127.0.0.1 farklıdır).
# - Redirect URLs (ikisini veya kullandığınızı ekleyin):
#   http://localhost:3000/auth/callback
#   http://127.0.0.1:3000/auth/callback
#   Yayında: https://alanadiniz.com/auth/callback
#   İsterseniz: http://localhost:3000/** gibi joker kullanabilirsiniz.
# Authentication → Providers → Google: Google Cloud’da Web istemcisi;
#   Authorized redirect URIs: https://PROJE_REF.supabase.co/auth/v1/callback
#   Authorized JavaScript origins: http://localhost:3000 (ve 127.0.0.1 gerekirse)

# TestSprite / E2E: Dashboard ve POST /api/generate-hooks oturum gerektirir.
# Supabase’da test kullanıcısı oluşturup (/login) e‑posta–şifre ile giriş akışını kullanın veya
# araçların kullanabileceği paylaşılan bir test hesabı tanımlayın. Anahtarları buraya yazmayın.
